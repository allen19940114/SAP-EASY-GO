# ========================================
# OLORA (SAP AI AGENT) Environment Configuration
# ========================================

# Application Configuration
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api
FRONTEND_URL=http://localhost:3001

# Database Configuration
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/olora

# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Session TTL (1 hour = 3600 seconds)
SESSION_TTL=3600

# JWT Authentication
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRES_IN=30d

# SAP Integration
# ========================================
SAP_API_URL=https://your-sap-server.com/sap/bc/rest
SAP_CLIENT=100
SAP_USERNAME=your-sap-username
SAP_PASSWORD=your-sap-password
SAP_TIMEOUT=30000

# LLM Provider Configuration
# ========================================
LLM_PROVIDER=openai
# Options: openai | deepseek | gemini

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.7

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.7

# Vector Database (Qdrant)
# ========================================
VECTOR_DB=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=olora_knowledge
# Vector dimension for text-embedding-3-large
VECTOR_DIMENSION=3072

# RAG Configuration
# ========================================
# Chunk size for document processing (512-1024 recommended)
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=200
# Number of similar chunks to retrieve
RAG_TOP_K=5
# Minimum similarity score (0.0-1.0)
RAG_MIN_SCORE=0.7

# File Upload Configuration
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
# 50MB in bytes (50 * 1024 * 1024)
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,txt,md

# Data Security Configuration
# ========================================
# Enable data sanitization for cloud LLM
ENABLE_DATA_SANITIZATION=true
# PII detection sensitivity (low|medium|high)
PII_DETECTION_LEVEL=high
# Mapping TTL in seconds (1 hour)
SENSITIVE_MAPPING_TTL=3600

# Audit Log Configuration
# ========================================
AUDIT_LOG_ENABLED=true
# Retention period in days
AUDIT_LOG_RETENTION_DAYS=90

# Email Configuration (Optional)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@olora.com

# Application Monitoring (Optional)
# ========================================
SENTRY_DSN=
LOG_LEVEL=info
# Options: error | warn | info | debug

# Rate Limiting
# ========================================
RATE_LIMIT_TTL=60
# Requests per minute
RATE_LIMIT_MAX=100

# CORS Configuration
# ========================================
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
