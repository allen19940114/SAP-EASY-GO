          "keywords": ["收货", "货物入库", "GR", "goods receipt"],
          "parameters": [
            {
              "name": "poNumber",
              "label": "采购订单号",
              "type": "string",
              "required": true
            },
            {
              "name": "items",
              "label": "收货项目",
              "type": "array",
              "required": true
            }
          ]
        },
        {
          "id": "MM_VENDOR_CREATE",
          "name": "创建供应商",
          "description": "创建供应商主数据 (MK01)",
          "tcode": "MK01",
          "api": "BAPI_VENDOR_CREATE",
          "method": "POST",
          "keywords": ["创建供应商", "新建供应商", "供应商主数据"],
          "parameters": [
            {
              "name": "vendorName",
              "label": "供应商名称",
              "type": "string",
              "required": true
