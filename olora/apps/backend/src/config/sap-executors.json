{
  "modules": [
    {
      "id": "MM",
      "name": "物料管理 (MM - Material Management)",
      "icon": "📦",
      "description": "采购、库存、供应商管理",
      "executors": [
        {
          "id": "MM_PO_CREATE",
          "name": "创建采购订单",
          "description": "创建标准采购订单 (ME21N)",
          "tcode": "ME21N",
          "api": "BAPI_PO_CREATE1",
          "method": "POST",
          "keywords": ["创建采购订单", "下采购单", "采购", "PO", "purchase order"],
          "parameters": [
            {
              "name": "supplier",
              "label": "供应商代码",
              "type": "string",
              "required": true,
              "description": "供应商编号"
            },
            {
              "name": "purchaseOrg",
              "label": "采购组织",
              "type": "string",
              "required": true,
              "default": "1000"
            },
            {
              "name": "purchaseGroup",
              "label": "采购组",
              "type": "string",
              "required": true
            },
            {
              "name": "items",
              "label": "采购项目",
              "type": "array",
              "required": true,
              "schema": {
                "material": "物料号",
                "quantity": "数量",
                "price": "单价",
                "deliveryDate": "交货日期",
                "plant": "工厂"
              }
            }
          ]
        },
        {
          "id": "MM_PO_DISPLAY",
          "name": "显示采购订单",
          "description": "查看采购订单详情 (ME23N)",
          "tcode": "ME23N",
          "api": "BAPI_PO_GETDETAIL",
          "method": "GET",
          "keywords": ["查看采购订单", "采购订单详情", "显示PO"],
          "parameters": [
            {
              "name": "poNumber",
              "label": "采购订单号",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "id": "MM_GR_POST",
          "name": "货物收货",
          "description": "货物收货过账 (MIGO)",
          "tcode": "MIGO",
